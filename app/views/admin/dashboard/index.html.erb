<% content_for :title, "Admin Dashboard" %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
  <p class="mt-2 text-gray-600">Welcome to the Blue Bird Mobile Dessert Bar admin panel</p>
</div>

<!-- Stats Overview -->
<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
  <!-- Gallery Images -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Gallery Images</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @gallery_images_count %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="bg-gray-50 px-5 py-3">
      <%= link_to "Manage Images", admin_gallery_images_path, class: "text-sm text-blue-600 hover:text-blue-900" %>
    </div>
  </div>

  <!-- Testimonials -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Testimonials</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @testimonials_count %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="bg-gray-50 px-5 py-3">
      <%= link_to "Manage Testimonials", admin_testimonials_path, class: "text-sm text-green-600 hover:text-green-900" %>
    </div>
  </div>

  <!-- Services -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Services</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @services_count %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="bg-gray-50 px-5 py-3">
      <%= link_to "Manage Services", admin_services_path, class: "text-sm text-purple-600 hover:text-purple-900" %>
    </div>
  </div>

  <!-- Featured Testimonials -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Featured</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @featured_testimonials_count %></dd>
          </dl>
        </div>
      </div>
    </div>
    <div class="bg-gray-50 px-5 py-3">
      <span class="text-sm text-gray-500">Featured testimonials</span>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Gallery Images -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Recent Gallery Images</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Latest uploaded images</p>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <% if @recent_gallery_images.any? %>
        <div class="space-y-3">
          <% @recent_gallery_images.each do |image| %>
            <div class="flex items-center space-x-3">
              <div class="flex-shrink-0 h-10 w-10">
                <% if image.image.attached? %>
                  <%= image_tag image.image.variant(resize_to_limit: [40, 40]), class: "h-10 w-10 rounded object-cover" %>
                <% else %>
                  <div class="h-10 w-10 rounded bg-gray-300 flex items-center justify-center">
                    <svg class="h-6 w-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= image.title %></p>
                <p class="text-sm text-gray-500"><%= image.category&.humanize %></p>
              </div>
            </div>
          <% end %>
        </div>
        <div class="mt-6">
          <%= link_to "View all images", admin_gallery_images_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No gallery images yet.</p>
        <%= link_to "Add first image", new_admin_gallery_image_path, class: "w-full flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      <% end %>
    </div>
  </div>

  <!-- Recent Testimonials -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Recent Testimonials</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Latest customer feedback</p>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <% if @recent_testimonials.any? %>
        <div class="space-y-4">
          <% @recent_testimonials.each do |testimonial| %>
            <div class="border-l-4 border-blue-400 pl-4">
              <div class="flex items-center space-x-2">
                <p class="text-sm font-medium text-gray-900"><%= testimonial.name %></p>
                <% if testimonial.featured? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">
                    Featured
                  </span>
                <% end %>
              </div>
              <p class="text-sm text-gray-600 mt-1 line-clamp-2"><%= truncate(testimonial.content, length: 100) %></p>
            </div>
          <% end %>
        </div>
        <div class="mt-6">
          <%= link_to "View all testimonials", admin_testimonials_path, class: "w-full flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-4">No testimonials yet.</p>
        <%= link_to "Add first testimonial", new_admin_testimonial_path, class: "w-full flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      <% end %>
    </div>
  </div>
</div>