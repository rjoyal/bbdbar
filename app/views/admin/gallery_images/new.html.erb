<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Add New Gallery Image</h1>
  <p class="mt-1 text-gray-600">Upload a new image to the gallery</p>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <%= form_with model: [:admin, @gallery_image], local: true, class: "space-y-6" do |form| %>
    <% if @gallery_image.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              There were <%= pluralize(@gallery_image.errors.count, "error") %> with your submission:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @gallery_image.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, 
                          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                          placeholder: "Enter image title" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, 
                         rows: 3,
                         class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                         placeholder: "Optional description of the image" %>
    </div>

    <div>
      <%= form.label :category, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :category, 
                      options_for_select([
                        ['Select category', ''],
                        ['Camper', 'camper'],
                        ['Desserts', 'desserts'],
                        ['Events', 'events'],
                        ['Setup', 'setup'],
                        ['Portraits', 'portraits']
                      ], @gallery_image.category),
                      {},
                      { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" } %>
    </div>

    <div>
      <%= form.label :image, class: "block text-sm font-medium text-gray-700" %>
      <%= form.file_field :image, 
                          accept: "image/*",
                          class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      <p class="mt-2 text-sm text-gray-500">PNG, JPG, GIF up to 10MB</p>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_gallery_images_path, 
                  class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= form.submit "Add Image", 
                      class: "bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700" %>
    </div>
  <% end %>
</div>