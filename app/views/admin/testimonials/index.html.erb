<div class="mb-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Testimonials</h1>
      <p class="mt-1 text-gray-600">Manage customer reviews and feedback</p>
    </div>
    <%= link_to "Add New Testimonial", new_admin_testimonial_path, 
                class: "bg-blue-600 text-white hover:bg-blue-700 px-4 py-2 rounded-md text-sm font-medium" %>
  </div>
</div>

<!-- Filter -->
<div class="mb-6">
  <div class="flex space-x-2">
    <%= link_to "All", admin_testimonials_path, 
                class: "px-3 py-2 text-sm rounded-md #{params[:featured].blank? ? 'bg-blue-100 text-blue-700' : 'text-gray-600 hover:text-gray-900'}" %>
    <%= link_to "Featured", admin_testimonials_path(featured: 'true'), 
                class: "px-3 py-2 text-sm rounded-md #{params[:featured] == 'true' ? 'bg-blue-100 text-blue-700' : 'text-gray-600 hover:text-gray-900'}" %>
  </div>
</div>

<div class="bg-white shadow rounded-lg">
  <% if @testimonials.any? %>
    <div class="divide-y divide-gray-200">
      <% @testimonials.each do |testimonial| %>
        <div class="p-6">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center space-x-3">
                <h3 class="text-lg font-medium text-gray-900"><%= testimonial.name %></h3>
                <% if testimonial.featured? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                    </svg>
                    Featured
                  </span>
                <% end %>
              </div>
              
              <% if testimonial.event_type.present? %>
                <p class="text-sm text-gray-500 mt-1">
                  <%= testimonial.event_type %>
                  <% if testimonial.event_date.present? %>
                    • <%= testimonial.event_date.strftime("%B %Y") %>
                  <% end %>
                </p>
              <% end %>
              
              <blockquote class="mt-3 text-gray-700">
                "<%= testimonial.content %>"
              </blockquote>
              
              <p class="text-sm text-gray-500 mt-3">
                Added <%= time_ago_in_words(testimonial.created_at) %> ago
              </p>
            </div>
            
            <div class="flex space-x-2 ml-4">
              <%= link_to "Edit", edit_admin_testimonial_path(testimonial), 
                          class: "text-blue-600 hover:text-blue-900 text-sm font-medium" %>
              <%= link_to "Delete", admin_testimonial_path(testimonial), 
                          method: :delete, 
                          data: { confirm: "Are you sure?" },
                          class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No testimonials</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by adding your first testimonial.</p>
      <div class="mt-6">
        <%= link_to "Add Testimonial", new_admin_testimonial_path, 
                    class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    </div>
  <% end %>
</div>