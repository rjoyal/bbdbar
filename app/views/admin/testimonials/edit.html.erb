<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Edit Testimonial</h1>
  <p class="mt-1 text-gray-600">Update customer feedback</p>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <%= form_with model: [:admin, @testimonial], local: true, class: "space-y-6" do |form| %>
    <% if @testimonial.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              There were <%= pluralize(@testimonial.errors.count, "error") %> with your submission:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @testimonial.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :client_name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :client_name, 
                          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                          placeholder: "Customer's name" %>
    </div>

    <div>
      <%= form.label :content, "Testimonial", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :content, 
                         rows: 4,
                         class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                         placeholder: "Customer's feedback or review" %>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :event_type, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :event_type, 
                            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                            placeholder: "e.g., Wedding, Birthday Party" %>
      </div>

      <div>
        <%= form.label :event_date, class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :event_date, 
                            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>
    </div>

    <div class="flex items-center">
      <div class="flex items-center h-5">
        <%= form.check_box :featured, 
                           class: "focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded" %>
      </div>
      <div class="ml-3 text-sm">
        <%= form.label :featured, "Feature this testimonial", class: "font-medium text-gray-700" %>
        <p class="text-gray-500">Featured testimonials appear prominently on the site</p>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", admin_testimonials_path, 
                  class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= form.submit "Update Testimonial", 
                      class: "bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700" %>
    </div>
  <% end %>
</div>