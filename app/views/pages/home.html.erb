<!-- app/views/pages/home.html.erb -->
<div class="min-h-screen">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-50 to-indigo-100 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
          Sweet Moments,<br>
          <span class="text-blue-600">Mobile Magic</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
          Blue Bird Mobile Dessert Bar brings handcrafted desserts, artisan coffee,
          and unforgettable experiences directly to your special events.
        </p>
        <%= link_to "Book Your Event", contact_path,
                    class: "inline-block bg-blue-600 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-blue-700 transition-colors" %>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">What We Offer</h2>
        <p class="text-lg text-gray-600">Premium catering services for every occasion</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% @services.each do |service| %>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold text-gray-900 mb-3"><%= service.name %></h3>
            <p class="text-gray-600 mb-4"><%= service.description %></p>
            <p class="text-blue-600 font-semibold"><%= service.pricing_info %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="bg-blue-600 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Create Sweet Memories?</h2>
      <p class="text-xl text-blue-100 mb-8">Let's make your next event unforgettable</p>
      <%= link_to "Schedule Consultation", contact_path,
                  class: "inline-block bg-white text-blue-600 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-100 transition-colors" %>
    </div>
  </section>
</div>